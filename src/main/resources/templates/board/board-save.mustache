{{> layout/header}}

<style>
    /* РћђРћђ BOARD SAVE РћђРћђ */
    .save-section { padding: 52px 28px 80px; }
    .save-inner { max-width: 760px; margin: 0 auto; }
    .save-header { margin-bottom: 32px; }
    .save-title { font-size: 24px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc { font-size: 14px; color: #9ca3af; font-weight: 400; }
    .save-form { display: flex; flex-direction: column; gap: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-input { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input::placeholder { color: #c4c9d9; }
    .form-input:focus { border-color: #2563eb; }
    .form-textarea { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; resize: vertical; min-height: 280px; line-height: 1.7; }
    .form-textarea::placeholder { color: #c4c9d9; }
    .form-textarea:focus { border-color: #2563eb; }
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .inquiry-type-btns { display: flex; gap: 8px; }
    .inquiry-type-btn {
        padding: 10px 22px; font-size: 13px; font-weight: 700;
        border: 1.5px solid #e2e5ef; border-radius: 20px;
        background: #fff; color: #9ca3af; cursor: pointer;
        transition: all .15s; font-family: inherit;
    }
    .inquiry-type-btn:hover { border-color: #2563eb; color: #2563eb; }
    .inquiry-type-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
</style>

<section class="save-section">
    <div class="save-inner">

        <div class="save-header">
            {{! boardTypeВЌљ вћ░вЮ╝ ВаювфЕ вХёЖИ░ }}
            {{#isFree}}
            <h1 class="save-title">ВъљВюаЖ▓їВІюьїљ ЖИђВЊ░ЖИ░</h1>
            <p class="save-desc">ВъљВюавАГЖ▓ї ВЮўЖ▓гВЮё вѓўвѕав│┤ВёИВџћ.</p>
            {{/isFree}}
            {{#isNotice}}
            <h1 class="save-title">Ж│хВДђВѓгьЋГ ВъЉВё▒</h1>
            <p class="save-desc">Ж│хВДђВѓгьЋГВЮё ВъЉВё▒ьЋЕвІѕвІц. Ж┤ђвдгВъљвДї ВъЉВё▒ Ж░ђвіЦьЋЕвІѕвІц.</p>
            {{/isNotice}}
            {{#isInquiry}}
                <h1 class="save-title">1:1 вгИВЮў ВъЉВё▒</h1>
                <p class="save-desc">1:1 вгИВЮўвЦ╝ ВъЉВё▒ьЋЕвІѕвІц.</p>
            {{/isInquiry}}
        </div>

        <form class="save-form" action="/boards/save" method="POST">
            
            {{! boardType ьъѕвЊа ьЋёвЊю Рђћ В╗еьіИвАцвЪгВЌљВёю FREE or NOTICE вёўЖ▓еВцўВЋ╝ ьЋе }}
            <input type="hidden" name="boardType" value="{{boardType}}" />
            {{#isInquiry}}
                <div class="form-group">
                    <label class="form-label">вгИВЮў ВюаьўЋ</label>
                    <input type="hidden" name="inquiryScope" id="inquiryScopeInput" value="NORMAL" />
                    <div class="inquiry-type-btns">
                        <button type="button" class="inquiry-type-btn active" onclick="selectScope('NORMAL', this)">ВЮ╝в░ўвгИВЮў</button>
                        <button type="button" class="inquiry-type-btn" onclick="selectScope('PAYMENT', this)">Ж▓░ВаювгИВЮў</button>
                        <button type="button" class="inquiry-type-btn" onclick="selectScope('SECURITY', this)">Ж│ёВаЋЖ┤ђвае</button>
                    </div>
                </div>
            {{/isInquiry}}
            <div class="form-group">
                <label class="form-label">ВаювфЕ</label>
                <input
                    type="text"
                    name="title"
                    class="form-input"
                    placeholder="ВаювфЕВЮё ВъЁваЦьЋўВёИВџћ"
                    maxlength="100"
                />
            </div>

            <div class="form-group">
                <label class="form-label">вѓ┤ВџЕ</label>
                <textarea
                    name="content"
                    class="form-textarea"
                    placeholder="вѓ┤ВџЕВЮё ВъЁваЦьЋўВёИВџћ"
                ></textarea>
            </div>

            <div class="form-btns">
                <a href="/boards?boardType={{boardType}}" class="btn btn-outline">ВиеВєї</a>
                <button type="submit" class="btn btn-primary">вЊ▒вАЮ</button>
            </div>

        </form>

    </div>
</section>
<script>
    function selectScope(scope, btn) {
        document.querySelectorAll('.inquiry-type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('inquiryScopeInput').value = scope;
    }
</script>
{{> layout/footer}}
