{{> layout/header}}
<style>

    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap { padding: 40px 28px 80px; position: relative; z-index: 1; }
    .page-header { text-align: center; margin-bottom: 32px; }
    .page-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -0.5px; margin-bottom: 6px; }
    .page-desc { font-size: 14px; color: #4a6fa5; }

    .board-editor-grid {
        display: grid; grid-template-columns: 220px 1fr 220px;
        gap: 20px; max-width: 1100px; margin: 0 auto; align-items: start;
    }
    .side-col { display: flex; flex-direction: column; gap: 14px; position: sticky; top: 84px; }
    .side-card {
        backdrop-filter: blur(16px); background: rgba(255,255,255,.58);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 18px; padding: 20px;
        box-shadow: 0 8px 28px rgba(37,99,235,.08);
    }
    .side-card-title {
        font-size: 11px; font-weight: 700; color: #2563eb;
        letter-spacing: .8px; text-transform: uppercase;
        margin-bottom: 14px; display: flex; align-items: center; gap: 6px;
    }
    .guide-list { display: flex; flex-direction: column; gap: 10px; }
    .guide-item { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; color: #2d4a7a; line-height: 1.5; }
    .guide-icon { flex-shrink: 0; color: #2563eb; margin-top: 1px; }
    .stat-row { display: flex; flex-direction: column; gap: 8px; }
    .stat-item {
        display: flex; justify-content: space-between; align-items: center;
        padding: 8px 10px; border-radius: 10px;
        background: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.8);
        font-size: 12px; color: #2d4a7a;
    }
    .stat-val { font-size: 13px; font-weight: 900; color: #1e3a6e; }
    .pop-list { display: flex; flex-direction: column; gap: 8px; }
    .pop-item { font-size: 12px; color: #2d4a7a; line-height: 1.5; display: flex; align-items: flex-start; gap: 6px; text-decoration: none; }
    .pop-item:hover { color: #2563eb; }
    .pop-num { font-size: 10px; font-weight: 700; color: #93aecf; flex-shrink: 0; margin-top: 2px; }

    /* 폼 카드 */
    .save-form {
        backdrop-filter: blur(20px); background: rgba(255,255,255,.58);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 24px; padding: 36px;
        display: flex; flex-direction: column; gap: 18px;
        box-shadow: 0 16px 48px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
    }
    .save-form::before { content:''; position:absolute; left:10%; right:10%; top:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,.9),transparent); }

    .form-group { display: flex; flex-direction: column; gap: 7px; }
    .form-label { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-input {
        padding: 13px 16px; background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(37,99,235,.15); border-radius: 12px;
        font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .15s;
    }
    .form-input::placeholder { color: #93aecf; }
    .form-input:focus { border-color: #2563eb; background: rgba(255,255,255,.95); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .form-textarea {
        padding: 13px 16px; background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(37,99,235,.15); border-radius: 12px;
        font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none;
        transition: all .15s; resize: vertical; min-height: 320px; line-height: 1.8;
    }
    .form-textarea::placeholder { color: #93aecf; }
    .form-textarea:focus { border-color: #2563eb; background: rgba(255,255,255,.95); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }

    /* 문의 유형 */
    .inquiry-type-btns { display: flex; gap: 8px; flex-wrap: wrap; }
    .inquiry-type-btn {
        padding: 8px 18px; font-size: 13px; font-weight: 700;
        border: 1.5px solid rgba(37,99,235,.2); border-radius: 20px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        color: #4a6fa5; cursor: pointer; transition: all .15s; font-family: inherit;
    }
    .inquiry-type-btn:hover { border-color: #2563eb; color: #2563eb; background: rgba(255,255,255,.9); }
    .inquiry-type-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; box-shadow: 0 4px 12px rgba(37,99,235,.25); }

    /* 글자수 */
    .char-row { display: flex; justify-content: space-between; align-items: center; }
    .char-count { font-size: 12px; color: #93aecf; }

    /* 파일 업로드 */
    .file-upload-zone {
        border: 2px dashed rgba(37,99,235,.25); border-radius: 14px; padding: 28px 20px;
        text-align: center; cursor: pointer; transition: all .2s;
        background: rgba(255,255,255,.5); position: relative;
    }
    .file-upload-zone:hover { border-color: #2563eb; background: rgba(239,246,255,.7); }
    .file-upload-zone.dragover { border-color: #2563eb; background: rgba(239,246,255,.85); transform: scale(1.01); }
    .file-upload-icon { color: #93aecf; margin-bottom: 10px; }
    .file-upload-zone:hover .file-upload-icon { color: #2563eb; }
    .file-upload-text { font-size: 13px; font-weight: 600; color: #4a6fa5; margin-bottom: 4px; }
    .file-upload-sub { font-size: 11px; color: #93aecf; }
    .file-upload-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

    /* 파일 미리보기 */
    .file-preview {
        display: none; align-items: center; gap: 12px; padding: 12px 14px;
        background: rgba(239,246,255,.8); border: 1px solid rgba(37,99,235,.2);
        border-radius: 10px; margin-top: 8px;
    }
    .file-preview.show { display: flex; }
    .file-preview-icon { color: #2563eb; flex-shrink: 0; }
    .file-preview-name { font-size: 13px; font-weight: 600; color: #1e3a6e; flex: 1; word-break: break-all; }
    .file-preview-remove {
        font-size: 12px; color: #93aecf; cursor: pointer; background: none; border: none;
        font-family: inherit; font-weight: 700; flex-shrink: 0; transition: color .15s;
    }
    .file-preview-remove:hover { color: #ef4444; }

    /* 기존 첨부파일 표시 */
    .existing-file {
        display: flex; align-items: center; gap: 10px; padding: 10px 14px;
        background: rgba(255,255,255,.6); border: 1px solid rgba(255,255,255,.85);
        border-radius: 10px; font-size: 13px; color: #2d4a7a;
    }
    .existing-file a { color: #2563eb; font-weight: 600; text-decoration: none; flex: 1; word-break: break-all; }
    .existing-file a:hover { text-decoration: underline; }

    /* 버튼 */
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 4px; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 11px 22px; border-radius: 20px; font-size: 14px; font-weight: 700; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; box-shadow: 0 4px 12px rgba(37,99,235,.25); }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.35); }
    .btn-outline { backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a; }
    .btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); }

    @media (max-width: 960px) { .board-editor-grid { grid-template-columns: 1fr; } .side-col { position: static; } }

</style>

<section class="page-wrap">
    <div class="page-header">
        {{#isFree}}<h1 class="page-title">자유게시판 글쓰기</h1><p class="page-desc">자유롭게 의견을 나눠보세요.</p>{{/isFree}}
        {{#isNotice}}<h1 class="page-title">공지사항 작성</h1><p class="page-desc">공지사항을 작성합니다. 관리자만 작성 가능합니다.</p>{{/isNotice}}
        {{#isInquiry}}<h1 class="page-title">1:1 문의 작성</h1><p class="page-desc">궁금한 점을 남겨주세요. 빠르게 답변드릴게요.</p>{{/isInquiry}}
    </div>

    <div class="board-editor-grid">

        <!-- 왼쪽: 작성 가이드 -->
        <div class="side-col">
            <div class="side-card">
                <div class="side-card-title">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M11 17h2v-6h-2v6zm0-8h2V7h-2v2zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                    작성 가이드
                </div>
                <div class="guide-list">
                    <div class="guide-item">
                        <span class="guide-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
                        제목은 핵심 내용만 명확하게
                    </div>
                    <div class="guide-item">
                        <span class="guide-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="#ef4444"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                        <span style="color:#ef4444;">욕설 및 비방 금지</span>
                    </div>
                    <div class="guide-item">
                        <span class="guide-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="#ef4444"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                        <span style="color:#ef4444;">무단 도용 금지</span>
                    </div>
                    <div class="guide-item">
                        <span class="guide-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg></span>
                        <span style="color:#b45309;">개인정보 유출 주의</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 가운데: 폼 -->
        <div>
            <form class="save-form" action="/boards/save" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="boardType" value="{{boardType}}"/>

                {{#isInquiry}}
                    <div class="form-group">
                        <label class="form-label">문의 유형</label>
                        <input type="hidden" name="inquiryScope" id="inquiryScopeInput" value="NORMAL"/>
                        <div class="inquiry-type-btns">
                            <button type="button" class="inquiry-type-btn active" onclick="selectScope('NORMAL',this)">일반문의</button>
                            <button type="button" class="inquiry-type-btn" onclick="selectScope('PAYMENT',this)">결제문의</button>
                            <button type="button" class="inquiry-type-btn" onclick="selectScope('SECURITY',this)">계정관련</button>
                        </div>
                    </div>
                {{/isInquiry}}

                <div class="form-group">
                    <label class="form-label">제목</label>
                    <input type="text" name="title" class="form-input" placeholder="제목을 입력하세요" maxlength="100"/>
                </div>

                <div class="form-group">
                    <div class="char-row">
                        <label class="form-label">내용</label>
                        <span class="char-count"><span id="charCount">0</span> / 2000</span>
                    </div>
                    <textarea name="content" class="form-textarea" id="contentInput" placeholder="내용을 입력하세요" maxlength="2000"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">첨부 파일 <span style="color:#93aecf;font-weight:500;">(선택, 최대 10MB)</span></label>
                    <div class="file-upload-zone" id="uploadZone">
                        <input type="file" name="attachmentFile" id="fileInput" class="file-upload-input"/>
                        <div class="file-upload-icon">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M16 12l-4-4m0 0L8 12m4-4v12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <p class="file-upload-text">파일을 드래그하거나 클릭하여 업로드</p>
                        <p class="file-upload-sub">이미지, PDF, 문서 등 최대 10MB</p>
                    </div>
                    <div class="file-preview" id="filePreview">
                        <svg class="file-preview-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg>
                        <span class="file-preview-name" id="fileName"></span>
                        <button type="button" class="file-preview-remove" id="removeFile">✕ 제거</button>
                    </div>
                </div>

                <div class="form-btns">
                    <a href="/boards?boardType={{boardType}}" class="btn btn-outline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                    취소
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                        등록
                    </button>
                </div>
            </form>
        </div>

        <!-- 오른쪽: 사이드 -->
        <div class="side-col">
            <div class="side-card">
                <div class="side-card-title">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20 22H6v-2h10V4H6V2h14v2h-2v16h2v2ZM6 7h2v2H6v2h2v2H6v2h2v2H6v3H4v-3H2v-2h2v-2H2v-2h2V9H2V7h2V4h2v3Z"/></svg>
                    게시판 안내
                </div>
                <div class="stat-row">
                    <div class="stat-item"><span>전체 게시글</span><span class="stat-val">12,345</span></div>
                </div>
            </div>
            {{#isFree}}
                <div class="side-card">
                    <div class="side-card-title">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b"><path d="M13 23h-2v-4h2v4Zm-2-4H9v-4h2v4Zm4 0h-2v-4h2v4Zm-6-4H5v-2h4v2Zm10-2v2h-4v-2h4ZM5 13H1v-2h4v2Zm18 0h-4v-2h4v2ZM9 11H5V9h4v2Zm10 0h-4V9h4v2Zm-8-2H9V5h2v4Zm4 0h-2V5h2v4Zm-2-4h-2V1h2v4Z"/></svg>
                        최근 인기 게시글
                    </div>
                    <div class="pop-list">
                        <a href="/boards" class="pop-item"><span class="pop-num">1</span>개발자로 전직하는 최고의 방법</a>
                        <a href="/boards" class="pop-item"><span class="pop-num">2</span>프리랜서 계약서 작성 시 주의사항</a>
                        <a href="/boards" class="pop-item"><span class="pop-num">3</span>포트폴리오 잘 만드는 팁 공유</a>
                    </div>
                </div>
            {{/isFree}}
            {{#isInquiry}}
                <div class="side-card">
                    <div class="side-card-title">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                        문의 안내
                    </div>
                    <div class="guide-list">
                        <div class="guide-item"><span>•</span>평균 답변 시간: <strong>5분</strong></div>
                        <div class="guide-item"><span>•</span>운영 시간: 평일 09~18시</div>
                        <div class="guide-item"><span>•</span>주말·공휴일 답변 지연될 수 있어요</div>
                    </div>
                </div>
            {{/isInquiry}}
        </div>

    </div>
</section>

<script>

    function selectScope(scope, btn) {
        document.querySelectorAll('.inquiry-type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('inquiryScopeInput').value = scope;
    }

    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const filePreview = document.getElementById('filePreview');
    const fileName = document.getElementById('fileName');
    const removeBtn = document.getElementById('removeFile');

    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
    uploadZone.addEventListener('drop', e => {
        e.preventDefault(); uploadZone.classList.remove('dragover');
        if (e.dataTransfer.files[0]) { fileInput.files = e.dataTransfer.files; showFile(e.dataTransfer.files[0]); }
    });
    fileInput.addEventListener('change', () => { if (fileInput.files[0]) showFile(fileInput.files[0]); });
    function showFile(f) {
        fileName.textContent = f.name + ' (' + (f.size/1024).toFixed(1) + ' KB)';
        filePreview.classList.add('show');
    }
    removeBtn.addEventListener('click', () => {
        fileInput.value = ''; filePreview.classList.remove('show'); fileName.textContent = '';
    });

    const contentEl = document.getElementById('contentInput');
    const charEl = document.getElementById('charCount');
    charEl.textContent = contentEl.value.length;
    contentEl.addEventListener('input', () => charEl.textContent = contentEl.value.length);

</script>
{{> layout/footer}}