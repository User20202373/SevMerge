{{> layout/header}}

<style>
    /* ── BOARD EDIT ── */
    .save-section { padding: 52px 28px 80px; }
    .save-inner { max-width: 760px; margin: 0 auto; }
    .save-header { margin-bottom: 32px; }
    .save-title { font-size: 24px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc { font-size: 14px; color: #9ca3af; font-weight: 400; }
    .save-form { display: flex; flex-direction: column; gap: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-input { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input::placeholder { color: #c4c9d9; }
    .form-input:focus { border-color: #2563eb; }
    .form-textarea { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; resize: vertical; min-height: 280px; line-height: 1.7; }
    .form-textarea::placeholder { color: #c4c9d9; }
    .form-textarea:focus { border-color: #2563eb; }
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .inquiry-type-btns { display: flex; gap: 8px; }
    .inquiry-type-btn {
        padding: 10px 22px; font-size: 13px; font-weight: 700;
        border: 1.5px solid #e2e5ef; border-radius: 20px;
        background: #fff; color: #9ca3af; cursor: pointer;
        transition: all .15s; font-family: inherit;
    }
    .inquiry-type-btn:hover { border-color: #2563eb; color: #2563eb; }
    .inquiry-type-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
</style>

<section class="save-section">
    <div class="save-inner">

        <div class="save-header">
            {{#isFree}}
                <h1 class="save-title">자유게시판 수정</h1>
                <p class="save-desc">게시글을 수정합니다.</p>
            {{/isFree}}
            {{#isNotice}}
                <h1 class="save-title">공지사항 수정</h1>
                <p class="save-desc">공지사항을 수정합니다.</p>
            {{/isNotice}}
            {{#isInquiry}}
                <h1 class="save-title">1:1 문의 수정</h1>
                <p class="save-desc">1:1 문의를 수정합니다.</p>
            {{/isInquiry}}
        </div>

        {{! action에 게시글 id 포함 — 컨트롤러에서 board.id 넘겨줘야 함 }}
        <form class="save-form" action="/boards/{{board.id}}/edit" method="POST">
            {{#isInquiry}}
                <div class="form-group">
                    <label class="form-label">문의 유형</label>
                    <input type="hidden" name="inquiryScope" id="inquiryScopeInput" />
                    <div class="inquiry-type-btns">
                        <button type="button" class="inquiry-type-btn" onclick="selectScope('NORMAL', this)">일반문의</button>
                        <button type="button" class="inquiry-type-btn" onclick="selectScope('PAYMENT', this)">결제문의</button>
                        <button type="button" class="inquiry-type-btn" onclick="selectScope('SECURITY', this)">계정관련</button>
                    </div>
                </div>
            {{/isInquiry}}
            <div class="form-group">
                <label class="form-label">제목</label>
                <input
                        type="text"
                        name="title"
                        class="form-input"
                        value="{{board.title}}"
                        placeholder="제목을 입력하세요"
                        maxlength="100"
                />
            </div>

            <div class="form-group">
                <label class="form-label">내용</label>
                <textarea
                        name="content"
                        class="form-textarea"
                        placeholder="내용을 입력하세요"
                >{{board.content}}</textarea>
            </div>

            <div class="form-btns">
                {{#isAdmin}}
                <a href="/boards/{{board.id}}" class="btn btn-outline">취소</a>
                {{/isAdmin}}
                {{^isAdmin}}
                    <a href="/boards/{{board.id}}" class="btn btn-outline">취소</a>
                {{/isAdmin}}

                <button type="button" onclick="updateBoard({{board.id}})" class="btn btn-primary">수정완료</button>
            </div>

        </form>

    </div>
</section>
<script>

    function selectScope(scope, btn) {
        document.querySelectorAll('.inquiry-type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('inquiryScopeInput').value = scope;
    }


    async function updateBoard(boardId) {
      try {
        const title = document.querySelector('input[name="title"]').value;
        const content = document.querySelector(
          'textarea[name="content"]',
        ).value;
          const inquiryScopeEl = document.getElementById('inquiryScopeInput');
          const inquiryScope = inquiryScopeEl ? inquiryScopeEl.value : null;

        const res = await fetch("/boards/" + boardId, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title, content, inquiryScope }),
        });
        if (res.ok) {
          location.href = "/boards/" + boardId;
        }
      } catch (e) {
        alert(e.message);
      }
    }
</script>
{{> layout/footer}}