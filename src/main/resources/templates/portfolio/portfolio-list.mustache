{{> layout/header}}

<style>
    /* ══ 글래스모피즘 배경 ══ */
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        min-height: 100vh;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }
    .bg-glow-3 { width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%); top: 40%; left: 30%; }

    .page-header {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.45);
        border-bottom: 1px solid rgba(255,255,255,.6);
        padding: 40px 28px 28px;
        position: relative; z-index: 1;
    }
    .page-header-inner { max-width: 1140px; margin: 0 auto; }
    .page-title { font-size: 26px; font-weight: 900; color: #0f172a; letter-spacing: -0.5px; margin-bottom: 6px; }
    .page-desc { font-size: 14px; color: #4a6fa5; }

    .list-section { padding: 36px 28px 80px; position: relative; z-index: 1; }
    .list-inner { max-width: 1140px; margin: 0 auto; }
    .list-action { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .list-count { font-size: 14px; color: #4a6fa5; font-weight: 500; }
    .list-count strong { color: #0f172a; font-weight: 700; }

    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary { background: #2563eb; color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,.3); }
    .btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(37,99,235,.4); }
    .btn-sm { padding: 8px 16px; font-size: 13px; border-radius: 7px; }

    .portfolio-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 36px; }
    .portfolio-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.5);
        border: 1.5px solid rgba(255,255,255,.75);
        border-radius: 18px; overflow: hidden;
        transition: transform .2s, box-shadow .2s, border-color .2s;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .portfolio-card:hover { border-color: rgba(255,255,255,.95); box-shadow: 0 12px 36px rgba(37,99,235,.12); transform: translateY(-4px); }
    .portfolio-card-img { width: 100%; height: 180px; background: rgba(219,234,254,.4); display: flex; align-items: center; justify-content: center; font-size: 48px; overflow: hidden; }
    .portfolio-card-img img { width: 100%; height: 100%; object-fit: cover; }
    .portfolio-card-body { padding: 20px; }
    .portfolio-title { font-size: 15px; font-weight: 700; color: #0f172a; margin-bottom: 8px; line-height: 1.4; }
    .portfolio-desc { font-size: 12px; color: #4a6fa5; line-height: 1.7; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .portfolio-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,.6); padding-top: 14px; }
    .portfolio-date { font-size: 11px; color: #94a3b8; }
    .portfolio-link { font-size: 12px; color: #2563eb; font-weight: 600; text-decoration: none; }
    .portfolio-link:hover { text-decoration: underline; }
    .empty-state { text-align: center; padding: 80px 0; }
    .empty-msg { font-size: 15px; color: #64748b; margin-bottom: 20px; }
    .paging { display: flex; justify-content: center; gap: 6px; }
    .page-btn { padding: 9px 15px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,.7); font-size: 13px; font-weight: 600; color: #4a6fa5; backdrop-filter: blur(8px); background: rgba(255,255,255,.45); text-decoration: none; transition: all .15s; }
    .page-btn:hover { border-color: rgba(37,99,235,.4); color: #2563eb; background: rgba(255,255,255,.7); }
    .page-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; box-shadow: 0 4px 12px rgba(37,99,235,.3); }
    /* ── FOOTER (exmain 스타일) ── */
    :root {
        --navy:      #0d1b2e;
        --cyan:      #00c8e0;
        --cyan-dark: #00a8be;
        --blue:      #2563eb;
        --blue-dark: #1d4ed8;
        --blue-soft: #eff6ff;
        --gray:      #6b7280;
        --gray-lt:   #9ca3af;
        --border:    #e5e7eb;
        --bg:        #f0f4fa;
    }

    body { background: var(--bg); font-family: 'Noto Sans KR', sans-serif; }

    /* 히어로 헤더 */
    .port-hero {
        background: linear-gradient(140deg, rgba(13,27,46,.92) 0%, rgba(14,42,74,.88) 60%, rgba(13,32,64,.94) 100%);
        padding: 48px 28px 44px; position: relative; overflow: hidden;
    }
    .port-hero::before {
        content: ''; position: absolute; inset: 0;
        background-image:
                linear-gradient(rgba(0,200,224,.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,200,224,.05) 1px, transparent 1px);
        background-size: 40px 40px; pointer-events: none;
    }
    .port-hero-inner {
        max-width: 1200px; margin: 0 auto;
        display: flex; align-items: center; justify-content: space-between; gap: 24px;
        position: relative; z-index: 1;
    }
    .port-hero-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(0,200,224,.12); border: 1px solid rgba(0,200,224,.3);
        border-radius: 999px; padding: 4px 14px;
        font-size: 11px; font-weight: 700; color: var(--cyan);
        margin-bottom: 14px; letter-spacing: .3px;
    }
    .port-hero-title {
        font-size: clamp(22px, 2.8vw, 34px); font-weight: 900; color: #fff;
        letter-spacing: -1px; line-height: 1.25; margin-bottom: 8px;
    }
    .port-hero-title .hl { color: var(--cyan); }
    .port-hero-desc { font-size: 14px; color: rgba(255,255,255,.5); line-height: 1.7; }
    .port-hero-action { flex-shrink: 0; }
    .btn-cyan {
        display: inline-flex; align-items: center; gap: 8px;
        background: var(--cyan); color: var(--navy);
        padding: 12px 24px; border-radius: 10px;
        font-size: 14px; font-weight: 800; transition: background .15s;
        text-decoration: none;
    }
    .btn-cyan:hover { background: var(--cyan-dark); }

    /* 본문 */
    .port-section { max-width: 1200px; margin: 0 auto; padding: 40px 28px 80px; }

    /* 상단 액션 바 */
    .port-action-bar {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 28px;
    }
    .port-count { font-size: 14px; color: var(--gray-lt); font-weight: 500; }
    .port-count strong { color: #0f172a; font-weight: 800; }

    /* 그리드 */
    .port-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px; margin-bottom: 40px;
    }

    /* 카드 */
    .port-card {
        background: #fff; border: 1.5px solid var(--border);
        border-radius: 18px; overflow: hidden;
        display: flex; flex-direction: column;
        transition: transform .2s, box-shadow .2s, border-color .2s;
        text-decoration: none; color: inherit;
    }
    .port-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 32px rgba(37,99,235,.10);
        border-color: #93c5fd;
    }
    .port-card-thumb {
        width: 100%; height: 190px;
        background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
        display: flex; align-items: center; justify-content: center;
        font-size: 52px; overflow: hidden; flex-shrink: 0; position: relative;
    }
    .port-card-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .port-card-body { padding: 20px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .port-card-title { font-size: 15px; font-weight: 800; color: #0f172a; line-height: 1.4; }
    .port-card-desc {
        font-size: 13px; color: var(--gray); line-height: 1.65;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        flex: 1;
    }
    .port-card-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 14px; border-top: 1px solid #f3f4f8; margin-top: auto;
    }
    .port-card-date { font-size: 11px; color: var(--gray-lt); }
    .port-card-links { display: flex; gap: 10px; align-items: center; }
    .port-link {
        font-size: 12px; font-weight: 700; color: var(--blue);
        text-decoration: none; transition: opacity .15s;
    }
    .port-link:hover { opacity: .7; }
    .port-ext-link {
        font-size: 12px; font-weight: 700; color: var(--gray);
        text-decoration: none; transition: color .15s;
    }
    .port-ext-link:hover { color: var(--blue); }

    /* 빈 상태 */
    .empty-state {
        background: #fff; border: 1.5px dashed var(--border);
        border-radius: 18px; padding: 64px; text-align: center;
        grid-column: span 3;
    }
    .empty-ico { font-size: 48px; margin-bottom: 16px; }
    .empty-msg { font-size: 15px; color: var(--gray-lt); margin-bottom: 20px; }

    /* 페이징 */
    .paging { display: flex; justify-content: center; align-items: center; gap: 8px; }
    .page-btn {
        padding: 9px 16px; border-radius: 8px;
        border: 1.5px solid var(--border);
        font-size: 13px; font-weight: 600; color: var(--gray);
        background: #fff; text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { border-color: var(--blue); color: var(--blue); }
    .page-btn.active { background: var(--blue); border-color: var(--blue); color: #fff; }

    @media (max-width: 960px) { .port-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) {
        .port-grid { grid-template-columns: 1fr; }
        .port-hero-inner { flex-direction: column; }
        .empty-state { grid-column: span 1; }
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<div class="page-header">
    <div class="page-header-inner">
        <h1 class="page-title">포트폴리오</h1>
        <p class="page-desc">{{expertProfile.memberName}} 전문가의 포트폴리오입니다.</p>
    </div>
</div>

<section class="list-section">
    <div class="list-inner">

        <div class="list-action">
            <span class="list-count">총 <strong>{{portfolioCount}}</strong>개의 포트폴리오</span>
            {{#isOwner}}
            <a href="/portfolios/save?expertId={{expertProfile.id}}" class="btn btn-primary btn-sm">+ 포트폴리오 추가</a>
            {{/isOwner}}
        </div>
<!-- 히어로 -->
<section class="port-hero">
    <div class="port-hero-inner">
        <div>
            <div class="port-hero-badge">💼 Portfolio</div>
            <h1 class="port-hero-title">{{expertProfile.memberName}} 전문가의<br><span class="hl">포트폴리오</span></h1>
            <p class="port-hero-desc">실력을 작업물로 직접 확인해보세요.</p>
        </div>
        {{#isOwner}}
            <div class="port-hero-action">
                <a href="/portfolios/save?expertId={{expertProfile.id}}" class="btn-cyan">
                + 포트폴리오 추가
                </a>
            </div>
        {{/isOwner}}
    </div>
</section>

<!-- 본문 -->
<div class="port-section">
    <div class="port-action-bar">
        <span class="port-count">총 <strong>{{portfolioCount}}</strong>개의 포트폴리오</span>
    </div>

    <div class="port-grid">
        {{#portfolios}}
            <div class="port-card">
                <div class="port-card-thumb">
                    {{#imageUrl}}
                        <img src="/images/portfolio/{{imageUrl}}" alt="{{title}}" onerror="this.parentElement.innerHTML='🖼️'" />
                    {{/imageUrl}}
                    {{^imageUrl}}🖼️{{/imageUrl}}
                </div>
                <div class="port-card-body">
                    <div class="port-card-title">{{title}}</div>
                    <div class="port-card-desc">{{description}}</div>
                    <div class="port-card-footer">
                        <span class="port-card-date">{{createdAt}}</span>
                        <div class="port-card-links">
                            {{#projectUrl}}
                                <a href="{{projectUrl}}" target="_blank" class="port-ext-link">🔗 보러가기</a>
                            {{/projectUrl}}
                            <a href="/portfolios/{{id}}" class="port-link">상세보기 →</a>
                        </div>
                    </div>
                </div>
            </div>
        {{/portfolios}}

        {{^portfolios}}
            <div class="empty-state">
                <div class="empty-ico">🖼️</div>
                <p class="empty-msg">아직 등록된 포트폴리오가 없습니다.</p>
                {{#isOwner}}
                    <a href="/portfolios/save?expertId={{expertProfile.id}}" class="btn-cyan">첫 포트폴리오 등록하기</a>
                {{/isOwner}}
            </div>
        {{/portfolios}}
    </div>

    <div class="paging">
        {{#hasPrev}}<a href="/portfolios?expertId={{expertProfile.id}}&page={{prevPage}}" class="page-btn">이전</a>{{/hasPrev}}
        <span class="page-btn active">{{currentPage}} / {{totalPages}}</span>
        {{#hasNext}}<a href="/portfolios?expertId={{expertProfile.id}}&page={{nextPage}}" class="page-btn">다음</a>{{/hasNext}}
    </div>
</div>

{{> layout/footer}}